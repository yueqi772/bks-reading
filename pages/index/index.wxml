<!-- pages/index/index.wxml -->
<view class="page-container">

  <!-- 顶部 Banner -->
  <view class="header">
    <view class="header-top flex-between">
      <view class="header-title">
        <text class="title-main">书解</text>
        <text class="title-sub">BookInsight</text>
      </view>
      <view wx:if="{{!isVip}}" class="free-badge" bindtap="goVip">
        <text class="free-count">{{freeCount}}</text>
        <text class="free-label">次可用</text>
      </view>
      <view wx:else class="vip-badge">
        <text class="tag-vip">VIP 无限</text>
      </view>
    </view>
    <view class="header-slogan">
      <text>让AI帮你深度解读每一本好书</text>
    </view>
    <view class="header-date">
      <text>📅 {{todayText}}</text>
    </view>
  </view>

  <!-- 非会员免费次数提示 -->
  <view wx:if="{{!isVip && freeCount > 0}}" class="free-tip-bar" bindtap="goVip">
    <text class="free-tip-text">🎁 新用户专享 · 剩余免费解读 {{freeCount}} 次</text>
    <text class="free-tip-arrow">›</text>
  </view>
  <view wx:if="{{!isVip && freeCount <= 0}}" class="out-tip-bar" bindtap="goVip">
    <text class="out-tip-text">⚡️ 免费次数已用完，开通会员畅读无限好书 →</text>
  </view>

  <!-- 每日推荐 -->
  <view wx:if="{{dailyRecommend}}" class="section">
    <view class="section-header flex-between">
      <text class="section-title">📚 今日推荐</text>
      <text class="section-date">{{todayText}}</text>
    </view>
    <view class="recommend-card card" bindtap="onRecommendTap">
      <view class="recommend-top flex-row">
        <view class="recommend-cover">
          <text class="recommend-emoji">📖</text>
        </view>
        <view class="recommend-info flex-1">
          <text class="recommend-title">《{{dailyRecommend.title}}》</text>
          <text class="recommend-author">{{dailyRecommend.author}}</text>
          <text class="recommend-reason text-ellipsis-2">{{dailyRecommend.reason}}</text>
        </view>
      </view>
      <view class="recommend-btn flex-row">
        <text class="recommend-btn-text">✨ 立即解读</text>
      </view>
    </view>
  </view>

  <!-- 书名输入区 -->
  <view class="section">
    <view class="section-title-row flex-between">
      <text class="section-title">🔍 输入书名</text>
    </view>
    <view class="input-card card">
      <view class="input-wrap flex-row">
        <input
          class="book-input flex-1"
          value="{{bookInput}}"
          placeholder="输入书名，开始深度解读..."
          placeholder-class="input-placeholder"
          bindinput="onBookInput"
          maxlength="100"
          confirm-type="search"
          bindconfirm="onStartRead"
        />
        <view wx:if="{{bookInput}}" class="input-clear" bindtap="clearInput">
          <text>✕</text>
        </view>
      </view>

      <!-- 解读模式选择 -->
      <view class="mode-row flex-row">
        <text class="mode-label">解读深度：</text>
        <view class="mode-tabs flex-row">
          <view
            class="mode-tab {{readMode === 'overview' ? 'active' : ''}}"
            data-mode="overview"
            bindtap="setMode"
          >概览</view>
          <view
            class="mode-tab {{readMode === 'standard' ? 'active' : ''}}"
            data-mode="standard"
            bindtap="setMode"
          >标准</view>
          <view
            class="mode-tab {{readMode === 'deep' ? 'active' : ''}}"
            data-mode="deep"
            bindtap="setMode"
          >深度</view>
        </view>
      </view>

      <!-- 开始解读按钮 -->
      <button class="start-btn btn-primary" bindtap="onStartRead">
        <text>开始深度解读 →</text>
      </button>
    </view>
  </view>

  <!-- 热门书单 -->
  <view class="section">
    <text class="section-title">🔥 热门书单</text>
    <scroll-view class="hot-books-scroll" scroll-x enable-flex>
      <view class="hot-books-list flex-row">
        <view
          wx:for="{{hotBooks}}"
          wx:key="title"
          class="hot-book-item card"
          data-title="{{item.title}}"
          bindtap="onHotBookTap"
        >
          <text class="hot-book-emoji">{{item.emoji}}</text>
          <text class="hot-book-title text-ellipsis">{{item.title}}</text>
          <text class="hot-book-author text-ellipsis">{{item.author}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 最近解读历史 -->
  <view wx:if="{{recentHistory.length > 0}}" class="section">
    <view class="section-header flex-between">
      <text class="section-title">🕐 最近解读</text>
      <text class="section-more" bindtap="goHistory">全部 ›</text>
    </view>
    <view
      wx:for="{{recentHistory}}"
      wx:key="id"
      class="history-item card"
      data-id="{{item.id}}"
      bindtap="onHistoryTap"
    >
      <view class="history-item-inner flex-between">
        <view class="history-info flex-1">
          <text class="history-title text-ellipsis">《{{item.bookTitle}}》</text>
          <text class="history-meta">{{item.modeText || '深度'}} · {{item.wordCount || 0}}字</text>
        </view>
        <text class="history-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部间距 -->
  <view class="footer-space"></view>

</view>

<!-- 付费弹窗 -->
<paywall
  show="{{showPaywall}}"
  freeCount="{{freeCount}}"
  bind:close="onPaywallClose"
  bind:goVip="onPaywallGoVip"
/>
