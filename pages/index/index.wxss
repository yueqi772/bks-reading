/* pages/index/index.wxss */

/* ===== 顶部 Header ===== */
.header {
  background: linear-gradient(160deg, #3a5231 0%, #4A6741 60%, #6B8F61 100%);
  padding: 60rpx 40rpx 50rpx;
  color: #FFFFFF;
}

.header-top {
  margin-bottom: 16rpx;
}

.title-main {
  font-size: 52rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-right: 12rpx;
}

.title-sub {
  font-size: 24rpx;
  opacity: 0.7;
  font-weight: 400;
}

.header-slogan {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 10rpx;
}

.header-date {
  font-size: 24rpx;
  opacity: 0.65;
}

.free-badge {
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
  padding: 8rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
}

.free-count {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFE566;
}

.free-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}

.vip-badge {
  padding: 8rpx 0;
}

/* ===== 次数提示条 ===== */
.free-tip-bar {
  background: #EEF4ED;
  padding: 18rpx 30rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.free-tip-text {
  font-size: 26rpx;
  color: #4A6741;
  font-weight: 500;
}

.free-tip-arrow {
  font-size: 30rpx;
  color: #4A6741;
}

.out-tip-bar {
  background: linear-gradient(135deg, #C9A85C 0%, #E8C97A 100%);
  padding: 18rpx 30rpx;
}

.out-tip-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ===== 区块 ===== */
.section {
  padding: 30rpx 30rpx 0;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.section-date {
  font-size: 24rpx;
  color: #999999;
}

.section-more {
  font-size: 26rpx;
  color: #4A6741;
}

/* ===== 每日推荐卡片 ===== */
.recommend-card {
  overflow: hidden;
}

.recommend-cover {
  width: 100rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #EEF4ED 0%, #D4E8D0 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.recommend-emoji {
  font-size: 50rpx;
}

.recommend-info {
  overflow: hidden;
}

.recommend-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.recommend-author {
  font-size: 24rpx;
  color: #666666;
  display: block;
  margin-bottom: 10rpx;
}

.recommend-reason {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.5;
}

.recommend-top {
  margin-bottom: 24rpx;
}

.recommend-btn {
  background: linear-gradient(135deg, #4A6741 0%, #6B8F61 100%);
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  justify-content: center;
}

.recommend-btn-text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ===== 输入区 ===== */
.section-title-row {
  margin-bottom: 20rpx;
}

.input-card {
  padding: 30rpx;
}

.input-wrap {
  background: #F7F5F0;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 88rpx;
  margin-bottom: 24rpx;
}

.book-input {
  font-size: 28rpx;
  color: #333333;
  height: 88rpx;
}

.input-placeholder {
  color: #BBBBBB;
}

.input-clear {
  color: #BBBBBB;
  font-size: 30rpx;
  padding: 0 10rpx;
}

/* ===== 解读模式 ===== */
.mode-row {
  margin-bottom: 24rpx;
}

.mode-label {
  font-size: 26rpx;
  color: #666666;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.mode-tabs {
  gap: 12rpx;
}

.mode-tab {
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666666;
  background: #F0F0F0;
  border: 2rpx solid transparent;
}

.mode-tab.active {
  background: #EEF4ED;
  color: #4A6741;
  border-color: #4A6741;
  font-weight: 600;
}

.start-btn {
  width: 100%;
  font-size: 30rpx;
}

/* ===== 热门书单 ===== */
.hot-books-scroll {
  width: 100%;
  white-space: nowrap;
}

.hot-books-list {
  padding: 4rpx 4rpx 16rpx;
  gap: 20rpx;
}

.hot-book-item {
  width: 180rpx;
  flex-shrink: 0;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10rpx;
}

.hot-book-emoji {
  font-size: 48rpx;
}

.hot-book-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #333333;
  width: 140rpx;
}

.hot-book-author {
  font-size: 20rpx;
  color: #999999;
  width: 140rpx;
}

/* ===== 历史记录 ===== */
.history-item {
  margin-bottom: 16rpx;
  padding: 24rpx 28rpx;
}

.history-info {
  overflow: hidden;
  margin-right: 20rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.history-meta {
  font-size: 22rpx;
  color: #999999;
}

.history-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}

/* ===== 底部间距 ===== */
.footer-space {
  height: 40rpx;
}
