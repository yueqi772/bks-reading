<!-- pages/profile/profile.wxml -->
<view class="page">

  <!-- 未登录状态 -->
  <view class="user-section" wx:if="{{!isLoggedIn}}" bindtap="showAuthModal">
    <view class="user-avatar">
      <text class="user-avatar-text">📖</text>
    </view>
    <view class="user-info">
      <view class="user-name" style="color:rgba(240,234,214,0.4);">点击登录</view>
      <view class="user-free-tag">登录后可同步数据、绑定会员</view>
    </view>
    <text class="menu-arrow" style="font-size:36rpx;">›</text>
  </view>

  <!-- 已登录状态 -->
  <view class="user-section" wx:else>
    <view class="user-avatar">
      <image wx:if="{{avatarUrl}}" class="user-avatar-img" src="{{avatarUrl}}" mode="aspectFill"/>
      <text wx:else class="user-avatar-text">{{isVip ? '👑' : '📖'}}</text>
    </view>
    <view class="user-info">
      <view class="user-name">{{nickName || '读书达人'}}</view>
      <view class="user-vip-tag" wx:if="{{isVip}}">VIP · {{vipExpireDate}} 到期</view>
      <view class="user-phone-tag" wx:elif="{{phone}}">{{phone}}</view>
      <view class="user-free-tag" wx:else>剩余 {{freeCount}} 次免费解读</view>
    </view>
    <view class="user-vip-entry" wx:if="{{!isVip}}" bindtap="goVip">开通 VIP</view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-row">
    <view class="stat-item">
      <view class="stat-num">{{totalBooks}}</view>
      <view class="stat-label">解读书目</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">{{totalWords}}</view>
      <view class="stat-label">字数积累</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">{{isVip ? '∞' : freeCount}}</view>
      <view class="stat-label">{{isVip ? '无限次数' : '剩余次数'}}</view>
    </view>
  </view>

  <!-- 我的内容 -->
  <view class="menu-group">
    <view class="menu-group-title">我的内容</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goHistory">
        <text class="menu-icon">🗂</text>
        <text class="menu-label">解读历史</text>
        <text class="menu-badge">{{totalBooks}}</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goVip">
        <text class="menu-icon">👑</text>
        <text class="menu-label">{{isVip ? '我的会员' : '开通会员'}}</text>
        <text class="menu-tag" wx:if="{{!isVip}}">¥30/月</text>
        <text class="menu-arrow">›</text>
      </view>
      <!-- 绑定手机号（仅已登录且未绑定时显示） -->
      <block wx:if="{{isLoggedIn && !phone}}">
        <button
          class="menu-item menu-item-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onBindPhone"
          loading="{{phoneLoading}}"
        >
          <text class="menu-icon">📱</text>
          <text class="menu-label">绑定手机号</text>
          <text class="menu-tag-orange">推荐</text>
          <text class="menu-arrow">›</text>
        </button>
      </block>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-group">
    <view class="menu-group-title">设置</view>
    <view class="menu-list">
      <view class="menu-item" bindtap="onAbout">
        <text class="menu-icon">💡</text>
        <text class="menu-label">关于书解</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onFeedback">
        <text class="menu-icon">📬</text>
        <text class="menu-label">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onClearCache">
        <text class="menu-icon">🧹</text>
        <text class="menu-label">清理缓存</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录（仅已登录时显示） -->
  <view class="logout-wrap" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>

  <view class="footer">BOOKSIGHT · 让好书照亮你的认知</view>
  <view style="height: 40rpx;"></view>

  <!-- 授权弹窗 -->
  <auth-modal show="{{showAuthModal}}" bind:done="onAuthDone" />
</view>
