<!-- pages/profile/profile.wxml -->
<view class="page-container">

  <!-- 用户信息区 -->
  <view class="user-section">
    <view wx:if="{{userInfo}}" class="user-info-card">
      <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view class="user-details">
        <text class="user-name">{{userInfo.nickName}}</text>
        <view wx:if="{{isVip}}" class="user-vip-row flex-row">
          <text class="tag-vip">VIP 会员</text>
          <text class="vip-expire">{{vipExpireText}}</text>
        </view>
        <view wx:else class="user-free-row">
          <text class="user-free-text">剩余免费次数：{{freeCount}} 次</text>
        </view>
      </view>
    </view>
    <view wx:else class="user-login-card" bindtap="getUserInfo">
      <view class="user-avatar-placeholder">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="user-details">
        <text class="user-name">点击授权</text>
        <text class="user-sub">登录后解锁更多功能</text>
      </view>
    </view>
  </view>

  <!-- 会员卡片 -->
  <view wx:if="{{!isVip}}" class="vip-card" bindtap="goVip">
    <view class="vip-card-left">
      <text class="vip-card-title">✨ 开通包月会员</text>
      <text class="vip-card-desc">无限次解读 · 历史永久保存</text>
    </view>
    <view class="vip-card-right">
      <text class="vip-price">¥30</text>
      <text class="vip-price-sub">/月</text>
    </view>
  </view>
  <view wx:else class="vip-active-card">
    <text class="vip-active-icon">👑</text>
    <view class="vip-active-info">
      <text class="vip-active-title">VIP 会员有效中</text>
      <text class="vip-active-desc">{{vipExpireText}} · 无限次深度解读</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-card card">
    <view class="stats-row flex-row">
      <view class="stats-item" bindtap="goHistory">
        <text class="stats-num">{{totalRead}}</text>
        <text class="stats-label">解读本数</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-num">{{totalWords}}</text>
        <text class="stats-label">累计字数</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item" bindtap="goFavorites">
        <text class="stats-num">{{favoriteCount}}</text>
        <text class="stats-label">我的收藏</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section card">
    <view class="menu-item flex-between" bindtap="goHistory">
      <view class="menu-left flex-row">
        <text class="menu-icon">📚</text>
        <text class="menu-text">解读历史</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item flex-between" bindtap="goFavorites">
      <view class="menu-left flex-row">
        <text class="menu-icon">❤️</text>
        <text class="menu-text">我的收藏</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item flex-between" bindtap="setFontSize">
      <view class="menu-left flex-row">
        <text class="menu-icon">🔤</text>
        <text class="menu-text">字体设置</text>
      </view>
      <view class="flex-row">
        <text class="menu-value">{{fontSizeText}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item flex-between" bindtap="contactService">
      <view class="menu-left flex-row">
        <text class="menu-icon">💬</text>
        <text class="menu-text">联系客服</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item flex-between" bindtap="goAbout">
      <view class="menu-left flex-row">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于书解</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 底部间距 -->
  <view style="height: 60rpx;"></view>

</view>

<!-- 联系客服弹窗 -->
<view wx:if="{{showContactQr}}" class="modal-mask mask" bindtap="closeContactQr">
  <view class="modal-box card" catchtap="">
    <text class="modal-title">联系客服</text>
    <text class="modal-desc">微信扫描下方二维码\n添加客服，发送「开通会员」</text>
    <view class="qr-placeholder">
      <text class="qr-icon">📱</text>
      <text class="qr-tip">客服二维码</text>
    </view>
    <button class="modal-close btn-secondary" bindtap="closeContactQr">关闭</button>
  </view>
</view>

<!-- 字体大小弹窗 -->
<view wx:if="{{showFontModal}}" class="modal-mask mask" bindtap="closeFontModal">
  <view class="font-modal card" catchtap="">
    <text class="modal-title">字体大小</text>
    <view class="font-options">
      <view
        class="font-option {{fontSize === 'small' ? 'active' : ''}}"
        data-size="small"
        bindtap="selectFont"
      >
        <text class="font-option-size font-small-demo">小号字体</text>
        <text class="font-option-check">{{fontSize === 'small' ? '✅' : ''}}</text>
      </view>
      <view
        class="font-option {{fontSize === 'medium' ? 'active' : ''}}"
        data-size="medium"
        bindtap="selectFont"
      >
        <text class="font-option-size font-medium-demo">中号字体</text>
        <text class="font-option-check">{{fontSize === 'medium' ? '✅' : ''}}</text>
      </view>
      <view
        class="font-option {{fontSize === 'large' ? 'active' : ''}}"
        data-size="large"
        bindtap="selectFont"
      >
        <text class="font-option-size font-large-demo">大号字体</text>
        <text class="font-option-check">{{fontSize === 'large' ? '✅' : ''}}</text>
      </view>
    </view>
    <button class="modal-close btn-secondary" bindtap="closeFontModal">确定</button>
  </view>
</view>
