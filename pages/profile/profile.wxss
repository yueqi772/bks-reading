/* pages/profile/profile.wxss — 深夜书房主题 */
.page { background: #111118; min-height: 100vh; padding: 0 0 40rpx; }

/* 用户区 */
.user-section {
  display: flex; align-items: center; gap: 24rpx;
  padding: 60rpx 40rpx 40rpx;
  background: linear-gradient(180deg, #1e1e2a 0%, #111118 100%);
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.user-avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%; flex-shrink: 0;
  background: #252535; border: 2rpx solid rgba(200,169,110,0.25);
  display: flex; align-items: center; justify-content: center;
}
.user-avatar-text { font-size: 44rpx; }
.user-info { flex: 1; }
.user-name { font-size: 30rpx; font-weight: 700; color: #F0EAD6; margin-bottom: 6rpx; }
.user-vip-tag { font-size: 21rpx; color: #C8A96E; }
.user-free-tag { font-size: 21rpx; color: rgba(240,234,214,0.35); }
.user-vip-entry {
  font-size: 21rpx; font-weight: 700; color: #111118;
  background: #C8A96E; padding: 8rpx 20rpx; border-radius: 30rpx; flex-shrink: 0;
}

/* 数据 */
.stats-row {
  display: flex; padding: 32rpx 40rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.stat-item { flex: 1; text-align: center; }
.stat-num { font-size: 38rpx; font-weight: 800; color: #F0EAD6; margin-bottom: 6rpx; }
.stat-label { font-size: 20rpx; color: rgba(240,234,214,0.3); letter-spacing: 1rpx; }
.stat-divider { width: 1rpx; background: rgba(255,255,255,0.05); margin: 10rpx 0; }

/* 菜单组 */
.menu-group { padding: 30rpx 40rpx 0; }
.menu-group-title { font-size: 20rpx; color: rgba(240,234,214,0.25); letter-spacing: 2rpx; margin-bottom: 14rpx; }
.menu-list { background: #1e1e2a; border-radius: 16rpx; overflow: hidden; border: 1rpx solid rgba(255,255,255,0.04); }
.menu-item {
  display: flex; align-items: center; padding: 26rpx 24rpx; gap: 18rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 34rpx; width: 44rpx; text-align: center; flex-shrink: 0; }
.menu-label { flex: 1; font-size: 27rpx; color: rgba(240,234,214,0.75); font-weight: 500; }
.menu-badge { font-size: 22rpx; color: rgba(240,234,214,0.3); }
.menu-tag {
  font-size: 20rpx; color: #C8A96E; background: rgba(200,169,110,0.1);
  padding: 3rpx 12rpx; border-radius: 10rpx;
  border: 1rpx solid rgba(200,169,110,0.2);
}
.menu-arrow { font-size: 30rpx; color: rgba(240,234,214,0.2); }
.user-avatar-img { width: 96rpx; height: 96rpx; border-radius: 50%; display: block; }
.user-phone-tag { font-size: 21rpx; color: rgba(240,234,214,0.45); }
.menu-item-btn {
  display: flex; align-items: center; padding: 26rpx 24rpx; gap: 18rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
  background: transparent; border-radius: 0; margin: 0; line-height: normal;
  text-align: left; width: 100%; box-sizing: border-box;
}
.menu-item-btn::after { border: none; }
.menu-tag-orange {
  font-size: 20rpx; color: #E8A855; background: rgba(232,168,85,0.1);
  padding: 3rpx 12rpx; border-radius: 10rpx;
  border: 1rpx solid rgba(232,168,85,0.2);
}

/* 退出登录 */
.logout-wrap { padding: 40rpx 40rpx 0; }
.logout-btn { text-align: center; padding: 28rpx 0; border-radius: 16rpx; font-size: 26rpx; color: rgba(220,80,80,0.7); background: rgba(220,80,80,0.06); border: 1rpx solid rgba(220,80,80,0.15); }

/* 底部 */
.footer { text-align: center; font-size: 20rpx; color: rgba(240,234,214,0.15); letter-spacing: 2rpx; padding: 50rpx 0 0; }
