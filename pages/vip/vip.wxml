<!-- pages/vip/vip.wxml -->
<view class="page">

  <!-- 已是会员 -->
  <view class="vip-active" wx:if="{{isVip}}">
    <view class="vip-active-badge">VIP</view>
    <view class="vip-active-title">您已是尊享会员</view>
    <view class="vip-active-expire">到期时间：{{vipExpireDate}}</view>
    <view class="vip-active-tip">会员期间享有无限次深度解读特权</view>
    <button class="renew-btn" bindtap="onRenew">续费会员</button>
  </view>

  <!-- 未开通 -->
  <view wx:else>

    <!-- 顶部背景 -->
    <view class="vip-hero">
      <view class="vip-hero-badge">VIP MEMBER</view>
      <view class="vip-hero-title">畅享无限解读</view>
      <view class="vip-hero-sub">让每一本好书都成为你的竞争力</view>
    </view>

    <!-- 权益 -->
    <view class="benefits-wrap">
      <view class="benefit-row">
        <view class="benefit-item">
          <text class="benefit-icon">♾</text>
          <view class="benefit-label">无限次解读</view>
        </view>
        <view class="benefit-item">
          <text class="benefit-icon">🔬</text>
          <view class="benefit-label">深度模式</view>
        </view>
        <view class="benefit-item">
          <text class="benefit-icon">📚</text>
          <view class="benefit-label">全书目畅读</view>
        </view>
        <view class="benefit-item">
          <text class="benefit-icon">🗂</text>
          <view class="benefit-label">永久存储</view>
        </view>
      </view>
    </view>

    <!-- 价格 -->
    <view class="price-wrap">
      <view class="price-main">
        <text class="price-symbol">¥</text>
        <text class="price-num">9.9</text>
        <text class="price-cycle"> / 月</text>
      </view>
      <view class="price-sub">随时可取消</view>
    </view>

    <!-- 开通步骤 -->
    <view class="steps-wrap">
      <view class="steps-title">开通步骤</view>
      <view class="step-row">
        <view class="step-num">1</view>
        <view class="step-text">截图保存下方收款码</view>
      </view>
      <view class="step-row">
        <view class="step-num">2</view>
        <view class="step-text">微信扫码，支付 9.9 元</view>
      </view>
      <view class="step-row">
        <view class="step-num">3</view>
        <view class="step-text">备注「书解会员 + 微信号」，添加微信 selavie_01</view>
      </view>
      <view class="step-row">
        <view class="step-num">4</view>
        <view class="step-text">客服确认后为你开通权限</view>
      </view>
    </view>

    <!-- 二维码 -->
    <view class="qr-wrap">
      <view class="qr-title">微信收款码</view>
      <image class="qr-img" src="/images/qr_pay.png" mode="aspectFit" bindtap="previewQr" />
      <view class="qr-tip">👆 点击图片可放大预览 / 长按保存</view>
      <view class="qr-amount">转账金额 <text class="qr-amount-num">¥ 9.90</text></view>
    </view>

    <!-- 客服 -->
    <view class="contact-wrap" bindtap="copyContact">
      <text class="contact-icon">💬</text>
      <view class="contact-info">
        <view class="contact-title">付款后添加微信，联系开通权限</view>
        <view class="contact-sub">客服微信：selavie_01</view>
      </view>
      <text class="contact-copy">复制</text>
    </view>

    <!-- 激活码 -->
    <view class="activate-wrap">
      <view class="activate-header" bindtap="toggleActivate">
        <text class="activate-title">已有激活码？</text>
        <text class="activate-arrow">{{showActivate?'∧':'∨'}}</text>
      </view>
      <view class="activate-body" wx:if="{{showActivate}}">
        <input class="activate-input" placeholder="输入激活码" value="{{activateCode}}" bindinput="onActivateInput" placeholder-class="activate-ph" />
        <button class="activate-btn" bindtap="onActivate">激活</button>
      </view>
    </view>

    <view style="height: 60rpx;"></view>
  </view>
</view>
