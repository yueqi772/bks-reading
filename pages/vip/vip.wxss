/* pages/vip/vip.wxss */

.page-container {
  min-height: 100vh;
  background-color: #F7F5F0;
}

/* ===== 顶部 ===== */
.vip-header {
  background: linear-gradient(135deg, #C9A85C 0%, #E8C97A 100%);
  padding: 60rpx 40rpx 70rpx;
  text-align: center;
}

.vip-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.vip-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* ===== 已是会员 ===== */
.vip-active-section {
  margin: -24rpx 24rpx 0;
  text-align: center;
  padding: 50rpx 30rpx;
  position: relative;
  z-index: 1;
}

.vip-active-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.vip-active-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #4A6741;
  margin-bottom: 10rpx;
}

.vip-active-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 400rpx;
  height: 88rpx;
  font-size: 28rpx;
}

/* ===== 权益卡片 ===== */
.benefits-card {
  margin: -24rpx 24rpx 16rpx;
  padding: 40rpx 30rpx 30rpx;
  position: relative;
  z-index: 1;
}

.benefits-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.benefit-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
  gap: 16rpx;
}

.benefit-item:last-child {
  border-bottom: none;
}

.benefit-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.benefit-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 6rpx;
}

.benefit-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

/* ===== 价格卡片 ===== */
.price-card {
  margin: 0 24rpx 16rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #FFF8EC 0%, #FFF3DC 100%);
  border: 2rpx solid #E8C97A;
}

.price-main {
  align-items: center;
  gap: 20rpx;
}

.price-num {
  font-size: 70rpx;
  font-weight: 700;
  color: #C9A85C;
}

.price-unit {
  font-size: 24rpx;
  color: #C9A85C;
  font-weight: 500;
}

.price-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.price-detail {
  font-size: 22rpx;
  color: #999999;
}

/* ===== 步骤卡片 ===== */
.steps-card {
  margin: 0 24rpx 16rpx;
  padding: 30rpx;
}

.steps-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.step-row {
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #4A6741;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-desc {
  font-size: 26rpx;
  color: #444444;
  line-height: 1.6;
  flex: 1;
}

/* ===== 收款码 ===== */
.qr-section {
  margin: 0 24rpx 16rpx;
  padding: 30rpx;
  text-align: center;
}

.qr-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.qr-box,
.contact-qr-box {
  width: 280rpx;
  height: 280rpx;
  background: #F5F5F5;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  border: 2rpx dashed #DDDDDD;
}

.qr-placeholder-text {
  font-size: 26rpx;
  color: #AAAAAA;
  margin-bottom: 8rpx;
}

.qr-placeholder-hint {
  font-size: 20rpx;
  color: #CCCCCC;
}

.pay-done-btn {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
}

/* ===== 客服联系 ===== */
.contact-section {
  margin: 0 24rpx 16rpx;
  padding: 30rpx;
  text-align: center;
}

.contact-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.contact-id {
  display: block;
  font-size: 26rpx;
  color: #4A6741;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.copy-btn {
  width: 100%;
  height: 80rpx;
  font-size: 26rpx;
}

/* ===== FAQ ===== */
.faq-section {
  margin: 0 24rpx 16rpx;
  padding: 30rpx;
}

.faq-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.faq-item {
  margin-bottom: 24rpx;
}

.faq-q {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.faq-a {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

/* ===== 支付成功弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.pay-success-modal {
  width: 100%;
  padding: 40rpx;
  text-align: center;
}

.pay-success-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.pay-success-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.pay-success-desc {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.8;
  text-align: left;
  margin-bottom: 30rpx;
  white-space: pre-wrap;
}

.pay-success-close {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
}
