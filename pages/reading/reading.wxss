/* pages/reading/reading.wxss — 深夜书房主题 */
.page { background: #111118; min-height: 100vh; padding: 40rpx; display: flex; flex-direction: column; }

.loading-stage { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.loading-book-wrap { display: flex; flex-direction: column; align-items: center; margin-bottom: 60rpx; }
.loading-book-cover {
  width: 160rpx; height: 220rpx; border-radius: 12rpx; overflow: hidden;
  margin-bottom: 24rpx; position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.6);
}
.loading-book-cover-img { width: 100%; height: 100%; display: block; }
.loading-book-cover-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,0.25);
  display: flex; align-items: center; justify-content: center;
}
.loading-book-emoji-badge { font-size: 52rpx; }
.loading-book-title { font-size: 28rpx; font-weight: 600; color: #F0EAD6; }

.loading-status { display: flex; align-items: center; gap: 16rpx; margin-bottom: 40rpx; }
.loading-dots-wrap { display: flex; gap: 8rpx; }
.dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #C8A96E; animation: dotBounce 1.4s infinite ease-in-out; }
.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
@keyframes dotBounce { 0%,80%,100% { transform: scale(0.5); opacity: 0.3; } 40% { transform: scale(1); opacity: 1; } }
.loading-tip { font-size: 24rpx; color: rgba(240,234,214,0.5); }

.loading-progress-wrap { width: 80%; display: flex; align-items: center; gap: 16rpx; margin-bottom: 50rpx; }
.loading-progress-bar { flex: 1; height: 4rpx; background: rgba(255,255,255,0.1); border-radius: 2rpx; overflow: hidden; }
.loading-progress-fill { height: 100%; background: #C8A96E; border-radius: 2rpx; transition: width 0.5s ease; }
.loading-progress-text { font-size: 22rpx; color: rgba(200,169,110,0.8); width: 60rpx; }

.loading-steps { width: 80%; display: flex; flex-direction: column; gap: 18rpx; }
.step { display: flex; align-items: center; gap: 16rpx; opacity: 0.25; transition: opacity 0.4s; }
.step-done { opacity: 1; }
.step-icon { font-size: 26rpx; width: 36rpx; }
.step-text { font-size: 24rpx; color: rgba(240,234,214,0.7); }
.step-done .step-text { color: #F0EAD6; }

.streaming-stage { flex: 1; display: flex; flex-direction: column; }
.streaming-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.streaming-book-tag { font-size: 22rpx; color: rgba(200,169,110,0.8); background: rgba(200,169,110,0.1); padding: 6rpx 16rpx; border-radius: 20rpx; border: 1rpx solid rgba(200,169,110,0.2); max-width: 300rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.streaming-status { display: flex; align-items: center; gap: 6rpx; }

/* 三点脉冲动画 */
.dot-pulse { width: 7rpx; height: 7rpx; border-radius: 50%; background: #C8A96E; animation: dotPulse 1.2s infinite ease-in-out; }
.dot-pulse-2 { animation-delay: 0.2s; }
.dot-pulse-3 { animation-delay: 0.4s; }
@keyframes dotPulse { 0%,80%,100% { transform: scale(0.6); opacity: 0.3; } 40% { transform: scale(1.1); opacity: 1; } }

.streaming-status-text { font-size: 20rpx; color: rgba(200,169,110,0.7); margin-left: 4rpx; }
.streaming-done-icon { font-size: 20rpx; color: #C8A96E; }
.streaming-status-done { color: rgba(200,169,110,0.9); }

.streaming-content {
  flex: 1; background: #1e1e2a; border-radius: 16rpx; padding: 28rpx 32rpx;
  border: 1rpx solid rgba(255,255,255,0.05);
  height: calc(100vh - 340rpx);
  box-sizing: border-box;
}
.streaming-rich {
  display: block;
  font-size: 28rpx;
  color: rgba(240,234,214,0.82);
  line-height: 1.85;
  word-break: break-all;
}
/* 块状光标 */
.cursor-blink { display: inline-block; font-size: 24rpx; color: #C8A96E; animation: cursorBlink 0.6s steps(1) infinite; vertical-align: text-bottom; margin-left: 2rpx; }
@keyframes cursorBlink { 0%,49% { opacity: 1; } 50%,100% { opacity: 0; } }
.streaming-footer { padding: 14rpx 0 0; text-align: right; }
.streaming-word-count { font-size: 20rpx; color: rgba(240,234,214,0.3); }

.done-stage { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; }
.done-icon { font-size: 90rpx; margin-bottom: 8rpx; }
.done-title { font-size: 38rpx; font-weight: 800; color: #F0EAD6; }
.done-sub { font-size: 26rpx; color: rgba(240,234,214,0.4); margin-bottom: 16rpx; }
.done-btn { width: 80%; height: 90rpx; line-height: 90rpx; text-align: center; background: #C8A96E; color: #111118; font-size: 28rpx; font-weight: 800; border-radius: 16rpx; border: none; padding: 0; }
.done-btn::after { border: none; }

.error-stage { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14rpx; }
.error-icon { font-size: 80rpx; margin-bottom: 8rpx; }
.error-title { font-size: 34rpx; font-weight: 700; color: #F0EAD6; }
.error-msg { font-size: 24rpx; color: rgba(240,234,214,0.4); text-align: center; padding: 0 40rpx; }
.error-tip { font-size: 22rpx; color: rgba(200,169,110,0.7); background: rgba(200,169,110,0.08); padding: 8rpx 24rpx; border-radius: 20rpx; }
.retry-btn { width: 80%; height: 90rpx; line-height: 90rpx; text-align: center; background: #C8A96E; color: #111118; font-size: 28rpx; font-weight: 800; border-radius: 16rpx; border: none; padding: 0; }
.retry-btn::after { border: none; }
.back-btn { width: 80%; height: 80rpx; line-height: 80rpx; text-align: center; background: transparent; color: rgba(240,234,214,0.35); font-size: 24rpx; border: none; padding: 0; }
.back-btn::after { border: none; }
