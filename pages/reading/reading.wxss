/* pages/reading/reading.wxss */

.page-container {
  min-height: 100vh;
  background-color: #F7F5F0;
}

/* ===== 加载阶段 ===== */
.loading-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.loading-book-cover {
  width: 160rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #EEF4ED 0%, #D4E8D0 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(74, 103, 65, 0.2);
}

.loading-book-emoji {
  font-size: 80rpx;
}

.loading-title {
  text-align: center;
  margin-bottom: 50rpx;
}

.loading-book-name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.loading-sub {
  font-size: 26rpx;
  color: #4A6741;
}

/* 进度条 */
.progress-wrap {
  width: 100%;
  margin-bottom: 50rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.progress-bar-bg {
  flex: 1;
  height: 12rpx;
  background: #E0E0E0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A6741 0%, #6B8F61 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-num {
  font-size: 24rpx;
  color: #4A6741;
  font-weight: 600;
  min-width: 60rpx;
}

/* 步骤列表 */
.step-list {
  width: 100%;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.step-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.step-item:last-child {
  border-bottom: none;
}

.step-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
}

.step-text {
  font-size: 26rpx;
  color: #666666;
}

.step-item.done .step-text {
  color: #4A6741;
  font-weight: 500;
}

.loading-tip {
  font-size: 26rpx;
  color: #4A6741;
  font-weight: 500;
  margin-bottom: 12rpx;
  text-align: center;
}

.loading-hint {
  font-size: 22rpx;
  color: #AAAAAA;
  text-align: center;
}

/* ===== 流式输出阶段 ===== */
.streaming-stage {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.stream-header {
  background: #FFFFFF;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #EBEBEB;
  flex-shrink: 0;
}

.stream-book-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 10rpx;
}

.stream-status {
  gap: 16rpx;
}

.stream-words {
  font-size: 22rpx;
  color: #999999;
}

.stream-scroll {
  flex: 1;
  height: 0;
}

.stream-content {
  padding: 30rpx;
}

.stream-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.cursor-blink {
  display: inline-block;
  width: 4rpx;
  height: 28rpx;
  background: #4A6741;
  animation: blink 1s infinite;
  vertical-align: middle;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* ===== 完成阶段 ===== */
.done-stage {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.done-header {
  margin: 20rpx;
  flex-shrink: 0;
}

.done-emoji {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.done-info {
  margin-bottom: 24rpx;
}

.done-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 6rpx;
}

.done-meta {
  font-size: 24rpx;
  color: #4A6741;
}

.done-actions {
  gap: 20rpx;
}

.done-btn-primary {
  height: 80rpx;
  font-size: 28rpx;
}

.done-scroll {
  flex: 1;
  height: 0;
}

.done-preview {
  padding: 20rpx 30rpx 60rpx;
}

.done-preview-text {
  font-size: 26rpx;
  color: #555555;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* ===== 错误阶段 ===== */
.error-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.error-msg {
  font-size: 26rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 12rpx;
}

.error-hint {
  font-size: 22rpx;
  color: #4A6741;
  margin-bottom: 60rpx;
}

.error-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.error-retry-btn {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
}

.error-back-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
}
