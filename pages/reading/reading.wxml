<!-- pages/reading/reading.wxml -->
<view class="page">

  <!-- 加载阶段 -->
  <view class="loading-stage" wx:if="{{stage === 'loading'}}">
    <view class="loading-book-wrap">
      <view class="loading-book-cover">
        <image class="loading-book-cover-img" src="https://images.unsplash.com/photo-1571834870678-24294e1ecf72?auto=format&fit=crop&w=200&q=80" mode="aspectFill" />
        <view class="loading-book-cover-overlay">
          <text class="loading-book-emoji-badge">📖</text>
        </view>
      </view>
      <view class="loading-book-title">《{{bookTitle}}》</view>
    </view>
    <view class="loading-status">
      <view class="loading-dots-wrap">
        <view class="dot"></view><view class="dot"></view><view class="dot"></view>
      </view>
      <view class="loading-tip">{{loadingTip}}</view>
    </view>
    <view class="loading-progress-wrap">
      <view class="loading-progress-bar">
        <view class="loading-progress-fill" style="width:{{progress}}%"></view>
      </view>
      <view class="loading-progress-text">{{progress}}%</view>
    </view>
    <view class="loading-steps">
      <view class="step {{step>=1?'step-done':''}}"><text class="step-icon">{{step>=1?'✦':'○'}}</text><text class="step-text">分析书籍结构</text></view>
      <view class="step {{step>=2?'step-done':''}}"><text class="step-icon">{{step>=2?'✦':'○'}}</text><text class="step-text">提炼核心观点</text></view>
      <view class="step {{step>=3?'step-done':''}}"><text class="step-icon">{{step>=3?'✦':'○'}}</text><text class="step-text">深度展开论证</text></view>
      <view class="step {{step>=4?'step-done':''}}"><text class="step-icon">{{step>=4?'✦':'○'}}</text><text class="step-text">生成案例与工具</text></view>
    </view>
  </view>

  <!-- 流式输出阶段 -->
  <view class="streaming-stage" wx:if="{{stage === 'streaming'}}">
    <view class="streaming-header">
      <view class="streaming-book-tag">{{bookTitle}}</view>
      <view class="streaming-status" wx:if="{{isStreaming}}">
        <view class="dot-pulse"></view>
        <view class="dot-pulse dot-pulse-2"></view>
        <view class="dot-pulse dot-pulse-3"></view>
        <text class="streaming-status-text">AI 正在解读</text>
      </view>
      <view class="streaming-status" wx:else>
        <text class="streaming-done-icon">✦</text>
        <text class="streaming-status-text streaming-status-done">解读完成</text>
      </view>
    </view>
    <scroll-view class="streaming-content" scroll-y scroll-top="{{scrollTop}}" enhanced>
      <rich-text class="streaming-rich" nodes="{{streamHtml}}"></rich-text>
      <text wx:if="{{isStreaming}}" class="cursor-blink">▋</text>
    </scroll-view>
    <view class="streaming-footer">
      <text class="streaming-word-count">{{wordCount}} 字</text>
    </view>
  </view>

  <!-- 完成阶段 -->
  <view class="done-stage" wx:if="{{stage === 'done'}}">
    <view class="done-icon">✦</view>
    <view class="done-title">解读完成</view>
    <view class="done-sub">共 {{wordCount}} 字深度解读</view>
    <button class="done-btn" bindtap="goDetail">阅读完整解读</button>
  </view>

  <!-- 错误阶段 -->
  <view class="error-stage" wx:if="{{stage === 'error'}}">
    <view class="error-icon">⚠</view>
    <view class="error-title">解读失败</view>
    <view class="error-msg">{{errorMsg}}</view>
    <view class="error-tip">本次不消耗解读次数</view>
    <button class="retry-btn" bindtap="retry">重新解读</button>
    <button class="back-btn" bindtap="goBack">返回首页</button>
  </view>

</view>
