/* pages/history/history.wxss — 深夜书房主题 */
.page { background: #111118; min-height: 100vh; padding: 30rpx 40rpx; }

.loading-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 160rpx 0; gap: 20rpx; }
.loading-spinner {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  border: 4rpx solid rgba(240,234,214,0.1);
  border-top-color: #C8A96E;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 24rpx; color: rgba(240,234,214,0.3); }

.empty-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 160rpx 0; gap: 16rpx; }
.empty-icon { font-size: 80rpx; opacity: 0.4; }
.empty-title { font-size: 30rpx; font-weight: 600; color: rgba(240,234,214,0.6); }
.empty-sub { font-size: 24rpx; color: rgba(240,234,214,0.3); }
.empty-btn {
  margin-top: 20rpx;
  width: 240rpx; height: 80rpx; line-height: 80rpx;
  background: #C8A96E; color: #111118;
  font-size: 28rpx; font-weight: 700;
  border-radius: 40rpx; border: none;
  padding: 0; box-sizing: border-box;
  text-align: center;
}
.empty-btn::after { border: none; }

.list-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 30rpx; }
.list-header-left { display: flex; align-items: baseline; gap: 12rpx; }
.list-title { font-size: 32rpx; font-weight: 800; color: #F0EAD6; letter-spacing: 1rpx; }
.list-count { font-size: 22rpx; color: rgba(240,234,214,0.35); }
.clear-btn { font-size: 22rpx; color: rgba(240,234,214,0.3); padding: 8rpx 0; }

.book-list { display: flex; flex-direction: column; gap: 2rpx; }
.book-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 24rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.book-item:last-child { border-bottom: none; }
.book-cover { width: 72rpx; flex-shrink: 0; }
.book-cover-img { width: 72rpx; height: 100rpx; border-radius: 8rpx; display: block; }
.book-info { flex: 1; min-width: 0; }
.book-title { font-size: 28rpx; font-weight: 700; color: #F0EAD6; margin-bottom: 8rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.book-meta-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 4rpx; }
.book-mode { font-size: 19rpx; color: #C8A96E; background: rgba(200,169,110,0.1); padding: 2rpx 10rpx; border-radius: 10rpx; }
.book-sep { font-size: 18rpx; color: rgba(240,234,214,0.2); }
.book-words { font-size: 21rpx; color: rgba(240,234,214,0.4); }
.book-time { font-size: 20rpx; color: rgba(240,234,214,0.25); margin-bottom: 8rpx; }
.book-cta { font-size: 21rpx; color: rgba(200,169,110,0.65); }
.book-del { font-size: 30rpx; color: rgba(240,234,214,0.15); padding: 10rpx; }
