<!-- pages/history/history.wxml -->
<view class="page-container">

  <!-- 统计栏 -->
  <view class="stats-bar flex-row">
    <view class="stat-item">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">解读记录</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{totalWords}}</text>
      <text class="stat-label">累计字数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{storageLimit}}</text>
      <text class="stat-label">存储额度</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-wrap flex-row">
    <text class="search-icon">🔍</text>
    <input
      class="search-input flex-1"
      value="{{searchKeyword}}"
      placeholder="搜索书名..."
      placeholder-class="search-placeholder"
      bindinput="onSearchInput"
    />
    <view wx:if="{{searchKeyword}}" class="search-clear" bindtap="clearSearch">
      <text>✕</text>
    </view>
  </view>

  <!-- 历史列表 -->
  <view wx:if="{{filteredHistory.length > 0}}" class="history-list">
    <view
      wx:for="{{filteredHistory}}"
      wx:key="id"
      class="history-card card"
      data-id="{{item.id}}"
      bindtap="onItemTap"
      data-item="{{item}}"
      bindlongpress="onItemLongPress"
    >
      <view class="history-card-top flex-between">
        <view class="history-book-icon">
          <text>📗</text>
        </view>
        <view class="history-main flex-1">
          <text class="history-book-title text-ellipsis">《{{item.bookTitle}}》</text>
          <text class="history-preview text-ellipsis-2">{{item.preview}}</text>
        </view>
        <text class="history-arrow">›</text>
      </view>
      <view class="history-card-bottom flex-between">
        <view class="flex-row" style="gap: 12rpx;">
          <text class="history-mode-tag">{{item.modeText}}</text>
          <text class="history-words">{{item.wordCount || 0}} 字</text>
        </view>
        <text class="history-date">{{item.createdAtText || ''}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{filteredHistory.length === 0 && historyList.length === 0}}" class="empty-state">
    <text class="empty-icon">📚</text>
    <text class="empty-text">暂无解读记录</text>
    <button class="go-home-btn btn-primary" bindtap="goHome">
      <text>去解读第一本书</text>
    </button>
  </view>

  <view wx:if="{{filteredHistory.length === 0 && historyList.length > 0}}" class="empty-state">
    <text class="empty-icon">🔍</text>
    <text class="empty-text">没有找到相关记录</text>
  </view>

  <!-- 底部提示（免费版限制） -->
  <view wx:if="{{historyList.length > 0}}" class="bottom-tip">
    <text class="bottom-tip-text">长按条目可删除或重新解读</text>
  </view>

  <!-- 底部间距 -->
  <view style="height: 40rpx;"></view>

</view>

<!-- 操作弹窗 -->
<view wx:if="{{showActionSheet}}" class="mask" bindtap="closeActionSheet">
  <view class="action-sheet" catchtap="">
    <view class="action-sheet-title">
      <text>《{{selectedItem.bookTitle}}》</text>
    </view>
    <view class="action-sheet-item" bindtap="onActionView">
      <text>👁️ 查看解读</text>
    </view>
    <view class="action-sheet-item" bindtap="onActionReRead">
      <text>🔄 重新解读</text>
    </view>
    <view class="action-sheet-item action-delete" bindtap="onActionDelete">
      <text>🗑️ 删除记录</text>
    </view>
    <view class="action-sheet-cancel" bindtap="closeActionSheet">
      <text>取消</text>
    </view>
  </view>
</view>
