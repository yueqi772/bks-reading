<!-- pages/history/history.wxml -->
<view class="page">

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading && historyList.length === 0}}">
    <view class="loading-spinner"></view>
    <view class="loading-text">正在加载书架...</view>
  </view>

  <!-- 未登录空状态 -->
  <view class="empty-wrap" wx:elif="{{!loading && !isLoggedIn && historyList.length === 0}}">
    <view class="empty-icon">🔐</view>
    <view class="empty-title">登录后查看书架</view>
    <view class="empty-sub">登录即可保存解读记录，随时回顾</view>
    <button class="empty-btn" bindtap="onLogin">登录 / 注册</button>
  </view>

  <!-- 已登录但无记录 -->
  <view class="empty-wrap" wx:elif="{{!loading && historyList.length === 0}}">
    <view class="empty-icon">📚</view>
    <view class="empty-title">书架还是空的</view>
    <view class="empty-sub">解读你的第一本书，开启知识之旅</view>
    <button class="empty-btn" bindtap="goHome">去解读</button>
  </view>

  <!-- 有内容 -->
  <view wx:elif="{{historyList.length > 0}}">
    <view class="list-header">
      <view class="list-header-left">
        <text class="list-title">我的书架</text>
        <text class="list-count">{{historyList.length}} 本</text>
      </view>
      <view class="clear-btn" bindtap="onClearAll">清空</view>
    </view>

    <view class="book-list">
      <view class="book-item" wx:for="{{historyList}}" wx:key="id" data-id="{{item.id}}" bindtap="onItemTap">
        <view class="book-cover">
          <image class="book-cover-img" src="https://images.unsplash.com/photo-1596522681657-8e9057309a7e?auto=format&fit=crop&w=100&q=80" mode="aspectFill" />
        </view>
        <view class="book-info">
          <view class="book-title">{{item.bookTitle}}</view>
          <view class="book-meta-row">
            <text class="book-mode">{{item.mode==='overview'?'概览':item.mode==='standard'?'标准':'深度'}}</text>
            <text class="book-sep">·</text>
            <text class="book-words">{{item.wordCount}} 字</text>
          </view>
          <view class="book-time">{{item.createdAtText}}</view>
          <view class="book-cta">继续阅读 →</view>
        </view>
        <view class="book-del" catchtap="onItemDelete" data-id="{{item.id}}">⌫</view>
      </view>
    </view>
  </view>

  <view style="height: 40rpx;"></view>

  <!-- 授权弹窗（未登录时触发登录用） -->
  <auth-modal show="{{showAuthModal}}" bind:done="onAuthDone" />
</view>
