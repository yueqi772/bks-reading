/* pages/detail/detail.wxss — 深夜书房主题 */
.page { background: #111118; min-height: 100vh; }

.detail-header {
  position: relative; height: 320rpx; overflow: hidden;
  display: flex; align-items: flex-end; padding: 30rpx 40rpx;
}
.detail-cover { position: absolute; inset: 0; }
.detail-cover-img { width: 100%; height: 100%; display: block; }
.detail-cover-mask {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(17,17,24,0.3) 0%, rgba(17,17,24,0.92) 100%);
}
.detail-meta { position: relative; z-index: 1; }
.detail-mode-tag {
  display: inline-block; font-size: 18rpx; color: #C8A96E;
  border: 1rpx solid rgba(200,169,110,0.5); border-radius: 20rpx;
  padding: 4rpx 14rpx; margin-bottom: 10rpx; letter-spacing: 1rpx;
}
.detail-book-title { font-size: 36rpx; font-weight: 800; color: #F0EAD6; margin-bottom: 8rpx; }
.detail-stats { font-size: 22rpx; color: rgba(240,234,214,0.45); }

.action-bar {
  display: flex; background: #1e1e2a; padding: 16rpx 40rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.05);
}
.action-btn { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; padding: 12rpx 0; }
.action-icon { font-size: 34rpx; color: rgba(240,234,214,0.6); }
.action-text { font-size: 20rpx; color: rgba(240,234,214,0.4); }
.action-del .action-icon { color: rgba(255,100,100,0.6); }
.action-del .action-text { color: rgba(255,100,100,0.5); }

.md-content { padding: 30rpx 40rpx; }
.md-rich {
  display: block;
  font-size: 28rpx;
  color: rgba(240,234,214,0.82);
  line-height: 1.85;
  word-break: break-all;
}
