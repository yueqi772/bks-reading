<!-- pages/detail/detail.wxml -->
<view class="page">

  <!-- 顶部书籍信息 -->
  <view class="detail-header">
    <view class="detail-cover">
      <image class="detail-cover-img" src="https://images.unsplash.com/photo-1571834870678-24294e1ecf72?auto=format&fit=crop&w=200&q=80" mode="aspectFill" />
      <view class="detail-cover-mask"></view>
    </view>
    <view class="detail-meta">
      <view class="detail-mode-tag">{{modeLabel}}</view>
      <view class="detail-book-title">《{{bookTitle}}》</view>
      <view class="detail-stats">{{wordCount}} 字 · {{createdAtText}}</view>
    </view>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar">
    <view class="action-btn" bindtap="onCopy"><text class="action-icon">⎘</text><text class="action-text">复制</text></view>
    <view class="action-btn" bindtap="onShare"><text class="action-icon">↗</text><text class="action-text">分享</text></view>
    <view class="action-btn action-del" bindtap="onDelete"><text class="action-icon">⌫</text><text class="action-text">删除</text></view>
  </view>

  <!-- 正文内容（rich-text 渲染 Markdown） -->
  <view class="md-content">
    <rich-text nodes="{{contentHtml}}" class="md-rich"></rich-text>
  </view>

  <view style="height: 80rpx;"></view>
</view>
