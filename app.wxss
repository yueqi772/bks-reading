/* app.wxss - 全局样式 */
page {
  background-color: #F7F5F0;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
}

/* ===== 主题色变量（通过 class 模拟）===== */
/* 主绿色 #4A6741 */
/* 浅绿色 #6B8F61 */
/* 背景米白 #F7F5F0 */
/* 卡片白 #FFFFFF */
/* 文字主色 #333333 */
/* 文字副色 #666666 */
/* 文字淡色 #999999 */
/* 分割线 #EBEBEB */
/* 金色 #C9A85C */

/* ===== 通用容器 ===== */
.container {
  padding: 0 30rpx;
}

.page-container {
  min-height: 100vh;
  background-color: #F7F5F0;
}

/* ===== 卡片样式 ===== */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* ===== 按钮样式 ===== */
.btn-primary {
  background: linear-gradient(135deg, #4A6741 0%, #6B8F61 100%);
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  height: 90rpx;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #FFFFFF;
  color: #4A6741;
  border: 2rpx solid #4A6741;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
}

.btn-secondary::after {
  border: none;
}

.btn-gold {
  background: linear-gradient(135deg, #C9A85C 0%, #E8C97A 100%);
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  height: 90rpx;
}

.btn-gold::after {
  border: none;
}

/* ===== 标签 ===== */
.tag-vip {
  background: linear-gradient(135deg, #C9A85C 0%, #E8C97A 100%);
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.tag-free {
  background: #EEF4ED;
  color: #4A6741;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background-color: #EBEBEB;
  margin: 20rpx 0;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #999999;
}

.empty-state .empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* ===== 加载中 ===== */
.loading-dots {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.loading-dots .dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4A6741;
  animation: dotBounce 1.4s infinite ease-in-out;
}

.loading-dots .dot:nth-child(1) { animation-delay: -0.32s; }
.loading-dots .dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* ===== 遮罩层 ===== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

/* ===== 文字截断 ===== */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ===== 弹性布局 ===== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-1 {
  flex: 1;
}
