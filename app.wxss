/* app.wxss — 深夜书房主题 */
page {
  background-color: #111118;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  color: #F0EAD6;
  font-size: 28rpx;
  line-height: 1.65;
}

.card {
  background: #1e1e2a;
  border-radius: 20rpx;
  padding: 30rpx;
}

.btn-primary {
  background: #F0EAD6;
  color: #111118;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border: none;
  letter-spacing: 1rpx;
}
.btn-primary::after { border: none; }

.text-gold { color: #C8A96E; }
.bg-gold { background: #C8A96E; }

.divider { height: 1rpx; background: rgba(255,255,255,0.07); }

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }
