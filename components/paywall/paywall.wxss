/* components/paywall/paywall.wxss */

.paywall-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.paywall-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
}

.paywall-panel {
  position: relative;
  z-index: 1;
  width: 100%;
  background: #FFFFFF;
  border-radius: 36rpx 36rpx 0 0;
  padding: 0 40rpx 60rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 顶部 */
.paywall-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 0 30rpx;
}

.paywall-crown {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.paywall-header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 10rpx;
}

.paywall-header-sub {
  font-size: 26rpx;
  color: #999999;
}

/* 权益 */
.paywall-benefits {
  background: #F7F5F0;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 30rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.benefit-icon {
  font-size: 30rpx;
  width: 40rpx;
}

.benefit-text {
  font-size: 26rpx;
  color: #444444;
}

/* 价格 */
.paywall-price {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.price-badge {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.price-symbol {
  font-size: 28rpx;
  font-weight: 700;
  color: #C9A85C;
}

.price-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #C9A85C;
  line-height: 1;
}

.price-unit {
  font-size: 28rpx;
  color: #999999;
}

/* 按钮 */
.paywall-btn-primary {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #C9A85C 0%, #E8C97A 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(201, 168, 92, 0.4);
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.paywall-btn-primary::after { border: none; }

.paywall-btn-cancel {
  width: 100%;
  height: 80rpx;
  background: transparent;
  color: #999999;
  font-size: 26rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.paywall-btn-cancel::after { border: none; }
