/* components/paywall/paywall.wxss — 深夜书房主题 */
.paywall-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.75);
  display: flex; align-items: flex-end; z-index: 999;
  backdrop-filter: blur(4px);
}
.paywall-sheet {
  width: 100%; background: #1A1A1A; border-radius: 28rpx 28rpx 0 0;
  padding: 12rpx 40rpx 60rpx;
  border-top: 1rpx solid rgba(255,255,255,0.07);
}
.sheet-handle {
  width: 60rpx; height: 6rpx; background: rgba(255,255,255,0.12);
  border-radius: 3rpx; margin: 0 auto 24rpx;
}
.sheet-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 30rpx; }
.sheet-title { font-size: 30rpx; font-weight: 700; color: #F0EAD6; }
.sheet-close { font-size: 28rpx; color: rgba(240,234,214,0.3); padding: 6rpx; }

/* 限制条 */
.limit-notice { margin-bottom: 30rpx; }
.limit-notice-text { font-size: 22rpx; color: rgba(240,234,214,0.4); margin-bottom: 10rpx; }
.limit-bar-fill {
  height: 6rpx; background: rgba(200,169,110,0.7);
  border-radius: 3rpx; transition: width 0.5s;
}
.limit-notice-bar { height: 6rpx; background: rgba(255,255,255,0.08); border-radius: 3rpx; overflow: hidden; }

/* 权益 */
.benefit-preview { display: flex; flex-direction: column; gap: 16rpx; margin-bottom: 34rpx; }
.benefit-p-item { display: flex; align-items: center; gap: 18rpx; }
.benefit-p-icon { font-size: 30rpx; width: 44rpx; text-align: center; }
.benefit-p-text { font-size: 25rpx; color: rgba(240,234,214,0.65); }

/* 价格 */
.paywall-price { text-align: center; margin-bottom: 28rpx; }
.price-big { font-size: 64rpx; font-weight: 900; color: #C8A96E; }
.price-period { font-size: 26rpx; color: rgba(240,234,214,0.4); }

/* 按钮 */
.paywall-cta {
  width: 100%; height: 96rpx; background: #F0EAD6; color: #0F0F0F;
  font-size: 30rpx; font-weight: 800; border-radius: 16rpx; border: none;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(240,234,214,0.12); letter-spacing: 2rpx;
}
.paywall-cta::after { border: none; }
.paywall-later { text-align: center; font-size: 24rpx; color: rgba(240,234,214,0.25); padding: 24rpx 0 0; }
