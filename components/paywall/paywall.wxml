<!-- components/paywall/paywall.wxml -->
<view class="paywall-wrap" wx:if="{{show}}">
  <!-- 背景遮罩 -->
  <view class="paywall-mask" bindtap="onClose"></view>

  <!-- 弹窗内容 -->
  <view class="paywall-panel">
    <!-- 顶部装饰 -->
    <view class="paywall-header">
      <view class="paywall-crown">👑</view>
      <view class="paywall-header-title">开通会员，畅读无限好书</view>
      <view class="paywall-header-sub">您的免费解读次数已用完</view>
    </view>

    <!-- 权益列表 -->
    <view class="paywall-benefits">
      <view class="benefit-item">
        <text class="benefit-icon">✨</text>
        <text class="benefit-text">无限次深度解读任意书籍</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">📚</text>
        <text class="benefit-text">全部书目无任何限制</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">🗂️</text>
        <text class="benefit-text">历史记录永久保存</text>
      </view>
      <view class="benefit-item">
        <text class="benefit-icon">🔬</text>
        <text class="benefit-text">概览/标准/深度三档随意切换</text>
      </view>
    </view>

    <!-- 价格 -->
    <view class="paywall-price">
      <view class="price-badge">
        <text class="price-symbol">¥</text>
        <text class="price-num">30</text>
        <text class="price-unit">/月</text>
      </view>
    </view>

    <!-- 按钮 -->
    <button class="paywall-btn-primary" bindtap="onGoVip">立即开通会员</button>
    <button class="paywall-btn-cancel" bindtap="onClose">暂不开通</button>
  </view>
</view>
