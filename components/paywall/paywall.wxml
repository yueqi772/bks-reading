<!-- components/paywall/paywall.wxml -->
<view wx:if="{{show}}" class="paywall-mask" bindtap="onClose">
  <view class="paywall-box" catchtap="">
    <!-- 关闭按钮 -->
    <view class="paywall-close" bindtap="onClose">✕</view>

    <!-- 图标 -->
    <view class="paywall-icon">📚</view>

    <!-- 标题 -->
    <text class="paywall-title">免费次数已用完</text>
    <text class="paywall-sub">开通包月会员，畅读无限好书</text>

    <!-- 价格 -->
    <view class="paywall-price-row">
      <text class="paywall-price">¥30</text>
      <text class="paywall-price-unit">/月</text>
    </view>

    <!-- 权益列表 -->
    <view class="paywall-benefits">
      <view class="paywall-benefit-item">
        <text class="paywall-benefit-check">✅</text>
        <text class="paywall-benefit-text">无限次深度解读任意书籍</text>
      </view>
      <view class="paywall-benefit-item">
        <text class="paywall-benefit-check">✅</text>
        <text class="paywall-benefit-text">所有书籍无限制访问</text>
      </view>
      <view class="paywall-benefit-item">
        <text class="paywall-benefit-check">✅</text>
        <text class="paywall-benefit-text">历史记录永久保存</text>
      </view>
    </view>

    <!-- 按钮 -->
    <button class="paywall-btn-vip btn-gold" bindtap="onGoVip">
      <text>立即开通会员</text>
    </button>
    <button class="paywall-btn-cancel" bindtap="onClose">
      <text>暂不开通</text>
    </button>
  </view>
</view>
