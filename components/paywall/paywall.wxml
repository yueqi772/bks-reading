<!-- components/paywall/paywall.wxml -->
<view class="paywall-mask" wx:if="{{show}}" bindtap="onMaskTap">
  <view class="paywall-sheet" catchtap>

    <!-- 顶部拖拽条 -->
    <view class="sheet-handle"></view>

    <!-- 标题 -->
    <view class="sheet-header">
      <view class="sheet-title">✦ 解读次数已用完</view>
      <view class="sheet-close" bindtap="onClose">✕</view>
    </view>

    <!-- 限制提示 -->
    <view class="limit-notice">
      <view class="limit-notice-text">免费体验已用完 {{freeCount}}/2 次</view>
      <view class="limit-notice-bar">
        <view class="limit-bar-fill" style="width:{{freeCount>=2?'100%':'50%'}}"></view>
      </view>
    </view>

    <!-- 权益预览 -->
    <view class="benefit-preview">
      <view class="benefit-p-item"><text class="benefit-p-icon">♾</text><text class="benefit-p-text">无限次深度解读</text></view>
      <view class="benefit-p-item"><text class="benefit-p-icon">📚</text><text class="benefit-p-text">全书目畅读</text></view>
      <view class="benefit-p-item"><text class="benefit-p-icon">🔬</text><text class="benefit-p-text">解锁深度模式</text></view>
    </view>

    <!-- 价格 -->
    <view class="paywall-price">
      <text class="price-big">¥30</text>
      <text class="price-period"> / 月</text>
    </view>

    <!-- 按钮 -->
    <button class="paywall-cta" bindtap="onGoVip">立即开通会员</button>
    <view class="paywall-later" bindtap="onClose">稍后再说</view>

  </view>
</view>
