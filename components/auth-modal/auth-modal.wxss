/* components/auth-modal/auth-modal.wxss */
.mask {
  position: fixed; inset: 0; z-index: 9999;
  background: rgba(0,0,0,0.72);
  display: flex; align-items: flex-end;
  backdrop-filter: blur(8px);
}
.sheet {
  width: 100%; background: #1a1a24;
  border-radius: 32rpx 32rpx 0 0;
  padding: 12rpx 44rpx 72rpx;
  border-top: 1rpx solid rgba(255,255,255,0.07);
  animation: slideUp 0.28s ease;
}
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

.handle {
  width: 64rpx; height: 6rpx; background: rgba(255,255,255,0.12);
  border-radius: 3rpx; margin: 0 auto 32rpx;
}

.logo { text-align: center; font-size: 52rpx; color: #C8A96E; margin-bottom: 14rpx; line-height: 1; }
.title { font-size: 34rpx; font-weight: 800; color: #F0EAD6; text-align: center; margin-bottom: 8rpx; }
.desc { font-size: 24rpx; color: rgba(240,234,214,0.4); text-align: center; margin-bottom: 36rpx; line-height: 1.7; }

/* 头像选择区 */
.avatar-wrap { display: flex; justify-content: center; align-items: center; margin-bottom: 28rpx; }
.avatar-btn {
  width: 120rpx !important; height: 120rpx !important;
  min-width: 120rpx; min-height: 120rpx;
  border-radius: 50%; padding: 0; margin: 0;
  background: #252535; border: 2rpx dashed rgba(200,169,110,0.4);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; flex-shrink: 0; box-sizing: border-box;
}
.avatar-btn::after { display: none; }
.avatar-img { width: 120rpx; height: 120rpx; min-width: 120rpx; min-height: 120rpx; border-radius: 50%; display: block; flex-shrink: 0; }
.avatar-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6rpx; }
.avatar-placeholder-icon { font-size: 34rpx; line-height: 1; }
.avatar-placeholder-text { font-size: 18rpx; color: rgba(200,169,110,0.6); }

/* 昵称输入框 */
.nickname-wrap {
  background: #252535; border-radius: 14rpx; padding: 0 24rpx;
  border: 1rpx solid rgba(255,255,255,0.07); margin-bottom: 20rpx;
}
.nickname-input {
  width: 100%; height: 90rpx; font-size: 28rpx; color: #F0EAD6;
  background: transparent; display: block;
}
.nickname-ph { color: rgba(240,234,214,0.25); font-size: 26rpx; }

/* 错误提示 */
.error-tip { font-size: 22rpx; color: #ff6b6b; text-align: center; margin-bottom: 12rpx; min-height: 32rpx; }

/* 按钮 */
.confirm-btn {
  width: 100%; height: 96rpx; background: #F0EAD6; color: #111118;
  border-radius: 18rpx; font-size: 30rpx; font-weight: 800; border: none;
  letter-spacing: 1rpx; box-shadow: 0 8rpx 32rpx rgba(240,234,214,0.12);
  display: flex; align-items: center; justify-content: center;
}
.confirm-btn::after { border: none; }
.btn-loading { background: #2a2a3a; color: rgba(240,234,214,0.3); box-shadow: none; }

.skip { text-align: center; font-size: 23rpx; color: rgba(240,234,214,0.22); padding: 24rpx 0 0; }

/* 完成状态 */
.done-wrap { display: flex; flex-direction: column; align-items: center; padding: 48rpx 0 24rpx; gap: 20rpx; }
.done-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; border: 3rpx solid rgba(200,169,110,0.35); display: block; }
.done-avatar-placeholder { font-size: 72rpx; color: #C8A96E; }
.done-title { font-size: 32rpx; font-weight: 800; color: #F0EAD6; }
.done-sub { font-size: 24rpx; color: rgba(240,234,214,0.4); }
